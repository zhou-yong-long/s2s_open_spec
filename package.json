{
  "name": "sdd-cli",
  "version": "0.1.0",
  "description": "Spec-Driven Development CLI",
  "type": "module",
  "bin": {
    "sdd": "./bin/sdd.js"
  },
  "files": [
    "bin",
    "dist",
    "scaffold",
    ".notes",
    "README.md"
  ],
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "bundle": "bash scripts/make-install-bundle.sh",
    "delivery:sync": "bash scripts/sync-delivery-kit.sh"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "js-yaml": "^4.1.0",
    "web-tree-sitter": "^0.26.7",
    "yargs": "^17.7.2"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.14.0",
    "@types/yargs": "^17.0.32",
    "tree-sitter-go": "^0.25.0",
    "tree-sitter-java": "^0.23.5",
    "tree-sitter-python": "^0.25.0",
    "tsx": "^4.19.0",
    "typescript": "^5.5.0",
    "vitest": "^1.6.0"
  }
}
